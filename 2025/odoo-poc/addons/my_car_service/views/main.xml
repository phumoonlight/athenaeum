                type="object" class="btn fa fa-asterisk" />
              <button name="do_accept"
                invisible="state not in ('needsAction', 'tentative', 'declined')" string="Accept"
                type="object" class="btn fa fa-check text-success" />
              <button name="do_decline"
                invisible="state not in ('needsAction', 'tentative', 'accepted')" string="Decline"
                type="object" class="btn fa fa-times-circle text-danger" />
            </footer> -->
          </t>
        </templates>
      </kanban>
    </field>
  </record>
