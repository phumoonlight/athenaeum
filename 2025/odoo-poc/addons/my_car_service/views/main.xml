<odoo>
  <!-- List View -->
  <record id="view_my_car_service_list" model="ir.ui.view">
    <field name="name">my_car_service.list</field>
    <field name="model">my_car_service.service</field>
    <field name="arch" type="xml">
      <list>
        <field name="service_type" />
        <field name="model" />
      </list>
    </field>
  </record>
  <!-- Kanban View -->
  <record id="view_my_car_service_kanban" model="ir.ui.view">
    <field name="name">my_car_service.kanban</field>
    <field name="model">my_car_service.service</field>
    <field name="arch" type="xml">
      <kanban create="false" delete="false">
        <templates>
          <t t-name="card">
            <field name="service_type" />
            <field name="model" />
            <!-- <span>Status: <field name="state" /></span> -->
